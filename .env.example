# Copie este arquivo para ".env" SÓ se for testar as functions localmente
# com `netlify dev`. Preencha com os valores reais apenas no seu .env local
# (que o .gitignore já bloqueia de ir pro Git) — em produção, essas mesmas
# chaves vão direto no painel do Netlify (Site settings > Environment
# variables), nunca em arquivo nenhum.

GMAIL_USER=
GMAIL_APP_PASSWORD=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Senha de acesso ao painel /dashboard.html — escolha algo forte, só vocês sabem
ADMIN_PASSWORD=
